{
  "name": "media-theme-neo",
  "version": "0.0.1",
  "type": "module",
  "description": "The Neo theme for Media Chrome",
  "keywords": [
    "neo",
    "media chrome",
    "media chrome theme",
    "video",
    "player",
    "web component",
    "custom element"
  ],
  "homepage": "https://github.com/luwes/media-theme-neo#readme",
  "bugs": {
    "url": "https://github.com/luwes/media-theme-neo/issues"
  },
  "main": "dist/media-theme-neo.js",
  "files": [
    "src",
    "dist"
  ],
  "repository": "luwes/media-theme-neo",
  "author": "Wesley Luyten <me@wesleyluyten.com> (https://wesleyluyten.com)",
  "license": "MIT",
  "scripts": {
    "test": "web-test-runner **/*test.js --coverage --config test/web-test-runner.config.js",
    "dev": "esbuild src/media-theme-neo.js --servedir=. --bundle --outdir=dist --loader:.svg=text --loader:.css=text",
    "build": "esbuild src/media-theme-neo.js --bundle --outdir=dist --sourcemap  --minify --loader:.svg=text --loader:.css=text",
    "prepublishOnly": "yarn build"
  },
  "prettier": {
    "tabWidth": 2,
    "singleQuote": true,
    "semi": true
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es6": true,
      "mocha": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    }
  },
  "devDependencies": {
    "@open-wc/testing": "^3.0.3",
    "@web/dev-server-esbuild": "^0.2.16",
    "@web/test-runner": "^0.13.26",
    "esbuild": "^0.14.30",
    "eslint": "^8.12.0",
    "prettier": "^2.6.1"
  },
  "dependencies": {
    "@github/jtml": "^0.4.1",
    "media-chrome": "^0.5.4"
  }
}
